{
  "name": "shopify-mcp-complete",
  "version": "1.1.0",
  "description": "Shopify MCP server for Claude Desktop. 33 tools covering products, bulk export, metafields, inventory, orders, customers, discounts, and store config.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "shopify-mcp-complete": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "shopify",
    "mcp",
    "model-context-protocol",
    "claude-desktop"
  ],
  "license": "MIT",
  "author": "Guillaume Picard",
  "repository": {
    "type": "git",
    "url": "https://github.com/gwpicard/shopify-mcp-complete.git"
  },
  "homepage": "https://github.com/gwpicard/shopify-mcp-complete",
  "bugs": {
    "url": "https://github.com/gwpicard/shopify-mcp-complete/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
